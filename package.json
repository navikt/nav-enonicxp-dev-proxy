{
    "name": "nav-enonicxp-dev-proxy",
    "version": "1.0.0",
    "private": true,
    "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
    "scripts": {
        "build": "rm -fr dist && tsc",
        "start": "node dist/server.js",
        "dev": "pnpm build && concurrently \"tsc -w\" \"nodemon -w dist dist/server.js\""
    },
    "nodemonConfig": {
        "env": {
            "NODE_ENV": "development"
        }
    },
    "dependencies": {
        "express": "4.22.1",
        "express-http-proxy": "2.1.2"
    },
    "devDependencies": {
        "@types/express": "4.17.21",
        "@types/express-http-proxy": "1.6.7",
        "@types/node": "24.1.0",
        "concurrently": "9.2.1",
        "eslint": "10.3.0",
        "nodemon": "3.1.14",
        "prettier": "3.8.3",
        "typescript": "5.9.3"
    }
}
